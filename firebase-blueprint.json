{
  "entities": {
    "Admin": {
      "title": "Admin",
      "description": "Administrator of the platform",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "addedAt"]
    },
    "Subject": {
      "title": "Subject",
      "description": "Normalized subject-centric database record serving multiple departments",
      "type": "object",
      "properties": {
        "subjectCode": { "type": "string" },
        "subjectName": { "type": "string" },
        "semester": { "type": "number" },
        "linked_departments": { "type": "array" },
        "credits": { "type": "number" },
        "type": { "type": "string" },
        "units": { "type": "array" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["subjectCode", "subjectName", "semester", "linked_departments"]
    },
    "Resource": {
      "title": "Resource",
      "description": "Academic resource (notes or PYQs) referenced by subject code relation",
      "type": "object",
      "properties": {
        "branch": { "type": "string" },
        "sem": { "type": "number" },
        "subjectCode": { "type": "string" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "fileUrl": { "type": "string" },
        "driveLink": { "type": "string" },
        "uploadedAt": { "type": "string", "format": "date-time" },
        "uploadedBy": { "type": "string" },
        "unit": { "type": "number" },
        "year": { "type": "number" },
        "department_visibility": { "type": "array" },
        "semester": { "type": "number" }
      },
      "required": ["subjectCode", "type", "title", "uploadedAt", "uploadedBy"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Global announcement displayed prominently to users",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string" },
        "imageUrl": { "type": "string" },
        "buttonText": { "type": "string" },
        "buttonUrl": { "type": "string" },
        "priority": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "type", "priority", "active", "createdAt"]
    }
  },
  "firestore": {
    "admins/{uid}": {
      "schema": "Admin",
      "description": "Platform administrators"
    },
    "subjects/{subjectCode}": {
      "schema": "Subject",
      "description": "Centralized database subjects"
    },
    "resources/{resourceId}": {
      "schema": "Resource",
      "description": "Centralized resources collection mapped by subjectCode"
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Global platforms updates and admin-published notifications"
    }
  }
}
