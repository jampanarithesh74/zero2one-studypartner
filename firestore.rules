rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isBootstrappableAdmin() {
      return isEmailVerified() && request.auth.token.email in [
        'jampanarithesh74@gmail.com',
        'jampanapadmaja7474@gmail.com',
        '25eg112c49@anurag.edu.in',
        'ritheshj899@gmail.com'
      ];
    }

    // Entity Validations
    function isValidAdmin(admin) {
      return admin.keys().hasAll(['email', 'addedAt']) && 
             admin.keys().size() == 2 &&
             admin.email is string && admin.email.size() <= 200 &&
             admin.addedAt == request.time &&
             admin.email == request.auth.token.email;
    }

    function isValidSubject(sub) {
      return sub.keys().hasAll(['subjectCode', 'subjectName', 'semester', 'linked_departments']) &&
             sub.keys().size() >= 4 && sub.keys().size() <= 8 &&
             sub.subjectCode is string && sub.subjectCode.size() <= 50 &&
             sub.subjectName is string && sub.subjectName.size() <= 500 &&
             sub.semester is number &&
             sub.linked_departments is list &&
             (!('credits' in sub) || sub.credits is number) &&
             (!('type' in sub) || sub.type is string) &&
             (!('units' in sub) || sub.units is list) &&
             (!('updatedAt' in sub) || sub.updatedAt == request.time);
    }

    function isValidResource(res) {
      return res.keys().hasAll(['subjectCode', 'type', 'title', 'uploadedAt', 'uploadedBy']) &&
             res.keys().size() >= 5 && res.keys().size() <= 13 &&
             res.subjectCode is string && res.subjectCode.size() <= 128 &&
             res.type is string && res.type in ['notes', 'pyqs'] &&
             res.title is string && res.title.size() <= 500 &&
             res.uploadedAt == request.time &&
             res.uploadedBy == request.auth.uid &&
             (!('fileUrl' in res) || res.fileUrl is string) &&
             (!('driveLink' in res) || res.driveLink is string) &&
             (!('unit' in res) || res.unit is number) &&
             (!('year' in res) || res.year is number) &&
             (!('branch' in res) || res.branch is string) &&
             (!('sem' in res) || res.sem is number) &&
             (!('semester' in res) || res.semester is number) &&
             (!('department_visibility' in res) || res.department_visibility is list);
    }

    // Collection Rules
    match /admins/{uid} {
      allow get: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid && (isBootstrappableAdmin() || isAdmin()) && isValidAdmin(incoming());
      allow update: if isAdmin() && isValidAdmin(incoming()) && incoming().email == existing().email;
      allow delete: if isAdmin();
    }

    match /subjects/{subjectCode} {
      allow read, list: if true; // Public access to subjects
      allow create, update: if isAdmin() && isValidSubject(incoming());
      allow delete: if isAdmin();
    }

    match /resources/{resourceId} {
      allow read, list: if true; // Public access to resources
      allow create: if isAdmin() && isValidResource(incoming());
      allow update: if isAdmin() && isValidResource(incoming()) && incoming().uploadedBy == existing().uploadedBy;
      allow delete: if isAdmin();
    }
  }
}
